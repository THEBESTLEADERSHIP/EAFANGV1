local function startStickyMode(button, getTargetPart, getPlayerCFrame, animId)
	local running = true
	local wasVoid = VoidProtection_Button.Ticket_Asset.ImageColor3 == Color3.fromRGB(0,255,0)
	if not wasVoid then ToggleVoidProtection(true) end
	if animId then PlayAnim(animId, 0, 1) end
	
	local connection
	connection = RunService.RenderStepped:Connect(function()
		if not running or button.Ticket_Asset.ImageColor3 == Color3.fromRGB(255,0,0) then
			running = false
			connection:Disconnect()
			StopAnim()
			if not wasVoid then ToggleVoidProtection(false) end
			return
		end
		pcall(function()
			local target = Players[TargetedPlayer]
			if not target or not target.Character then return end
			local part = getTargetPart(target)
			if not part then return end
			local root = GetRoot(plr)
			if not root then return end
			root.CFrame = getPlayerCFrame(part)
			root.Velocity = Vector3.new(0,0,0)
			plr.Character.Humanoid.PlatformStand = true
		end)
	end)
end

-- Copy Anim (Replaces Fling) - Copies target's playing animation
CopyAnim_Button.MouseButton1Click:Connect(function()
	if TargetedPlayer then
		ChangeToggleColor(CopyAnim_Button)
		if CopyAnim_Button.Ticket_Asset.ImageColor3 == Color3.fromRGB(0,255,0) then
			local target = Players[TargetedPlayer]
			if target and target.Character then
				local hum = target.Character:FindFirstChildOfClass("Humanoid")
				if hum then
					local tracks = hum:GetPlayingAnimationTracks()
					for _, track in pairs(tracks) do
						local animId = track.Animation.AnimationId
						if animId and animId:match("rbxassetid://(%d+)") then
							local id = animId:match("rbxassetid://(%d+)")
							PlayAnim(id, track.TimePosition, track.Speed)
							SendNotify("System Broken","Copied animation: "..id,3)
							break
						end
					end
				end
			end
		end
	end
end)

-- Copy Chat (Replaces Focus) - Copies target's chat messages
CopyChat_Button.MouseButton1Click:Connect(function()
	if TargetedPlayer then
		ChangeToggleColor(CopyChat_Button)
		if CopyChat_Button.Ticket_Asset.ImageColor3 == Color3.fromRGB(0,255,0) then
			local target = Players[TargetedPlayer]
			local connection
			connection = game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.OnMessageDoneFiltering.OnClientEvent:Connect(function(data)
				if data.FromSpeaker == target.Name then
					local msg = data.Message
					if msg and msg ~= "" then
						Players:Chat(msg)
						SendNotify("System Broken","Copied chat: "..msg,3)
					end
				end
			end)
			-- Store connection to disconnect when toggled off
			CopyChat_Button._connection = connection
			repeat task.wait(0.5) until CopyChat_Button.Ticket_Asset.ImageColor3 == Color3.fromRGB(255,0,0)
			if connection then connection:Disconnect() end
		else
			if CopyChat_Button._connection then
				CopyChat_Button._connection:Disconnect()
				CopyChat_Button._connection = nil
			end
		end
	end
end)

